#
# ~/.bashrc
#

# Enable dynamic line wrap
shopt -s checkwinsize

#################
# General Aliases

# Navigational

alias ..='cd ..'
alias ...='cd ..; cd ..'
alias ....='cd ..; cd ..; cd ..'
alias g='cd'
alias r='cd "$OLDPWD"'
alias l='ls --color=auto'
alias la='ls -A --color=auto'
alias ll='ls -lh --color=auto'
alias lll='ls -Alh --color=auto'
alias q='exit'

# Frequently Used

alias c='clear'
alias e='"$EDITOR"'

####################
# Host-specific Info

{{ if eq .hosttype "desktop" -}}
# Git-specific Aliases

alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gcm='git commit -m'
alias gb='git branch'
alias gch='git checkout'
alias gpl='git pull'
alias gps='git push'

# Command Prompt
export GIT_PS1_SHOWCOLORHINTS=1
export GIT_PS1_SHOWDIRTYSTATE=1
export GIT_PS1_SHOWSTASHSTATE=1
export GIT_PS1_SHOWUNTRACKEDFILES=1
export GIT_PS1_SHOWUPSTREAM=1
export PS1="[\[\e[36m\]\t\[\e[m\]]-[\[\e[32m\]\u\[\e[m\]\[\e[32m\]@\[\e[m\]\[\e[32m\]\h\[\e[m\]]-[\[\e[35m\]\W\[\e[m\]]\$(__git_ps1 "-[%s]")\n\\$> "

{{- else if eq .hosttype "server" -}}
# Command Prompt
export PS1="[\[\e[36m\]\t\[\e[m\]]-[\[\e[32m\]\u\[\e[m\]\[\e[32m\]@\[\e[m\]\[\e[32m\]\h\[\e[m\]]-[\[\e[35m\]\W\[\e[m\]]\n\\$> "

{{- end }}
