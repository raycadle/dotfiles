    "custom/updates": {
        "exec": "~/.config/hypr/scripts/systemupdate.sh",
        "return-type": "json",
        "format": "󰚰",
        "format-alt": "{} 󰚰",
        "on-click-right": "~/.config/hypr/scripts/systemupdate.sh u",
        "interval": 3600, // once every day
        "tooltip": true
    },

