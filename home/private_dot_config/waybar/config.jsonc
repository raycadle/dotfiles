//   --// waybar config generated by wbarconfgen.sh //--   //

{
// sourced from header module //

    "layer": "top",
    "position": "top",
    "mod": "dock",
    "height": 15,
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,


// positions generated based on config.ctl //

	"modules-left": ["custom/padd","custom/l_end","custom/launcher","hyprland/workspaces","custom/r_end","custom/l_end","wlr/taskbar","hyprland/window","custom/r_end","custom/padd"],
	"modules-center": ["custom/padd","custom/l_end","idle_inhibitor","clock","custom/r_end","custom/padd"],
	"modules-right": ["custom/padd","custom/l_end","tray","battery","custom/r_end","custom/l_end","custom/wallchange","custom/mode","custom/wbar","custom/cliphist","custom/r_end","custom/l_end","backlight","network","bluetooth","pulseaudio","pulseaudio#microphone","custom/updates","custom/notification","custom/power","custom/r_end","custom/padd"],


// sourced from modules based on config.ctl //

    "custom/launcher": {
        "format": "َ°£‡ ",
        "tooltip": false,
        "on-click": "pkill -x rofi || ~/.config/hypr/scripts/rofilaunch.sh d",
        "on-click-right": "pkill -x rofi || ~/.config/hypr/scripts/rofilaunch.sh r",
        "on-click-middle": "pkill -x rofi || ~/.config/hypr/scripts/rofilaunch.sh w"
    },
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "active-only": false,
        "on-click": "activate",
        "persistent-workspaces": {
        }
    },

	"wlr/taskbar": {
		"format": "{icon}",
		"icon-size": 16,
		"icon-theme": "Tela-circle-dracula",
        "spacing": 0,
		"tooltip-format": "{title}",
		"on-click": "activate",
		"on-click-middle": "close",
		"ignore-list": [
			"Alacritty",
      "keyb"
		],
		"app_ids-mapping": {
			"firefoxdeveloperedition": "firefox-developer-edition"
		}
	},

    "hyprland/window": {
        "format": " {}",
        "separate-outputs": true,
        "rewrite": {
            "nigga@arch:(.*)": "$1 ï’‰ ",
            "(.*)zsh": "$1 ï’‰ ",
            "(.*)tmux": "$1 ï’‰ ",
            "(.*) â€” Mozilla Firefox": "$1 َ°ˆ¹ ",
            "(.*)Mozilla Firefox": "Firefox َ°ˆ¹ ",
            "(.*) - VSCodium": "$1 َ°¨‍ ",
            "(.*)VSCodium": "Codium َ°¨‍ ",
            "(.*) â€” Dolphin": "$1 َ°‰‹ ",
            "(.*)Spotify": "Spotify َ°“‡ ",
            "(.*)Steam": "Steam َ°““ "
        },
        "max-length": 1000,
        "on-click": "pkill -x rofi || ~/.config/hypr/scripts/rofilaunch.sh w",
        "on-click-right": "hyprctl dispatch killactive"
    },

    "idle_inhibitor": {
        "format": "{icon} ",
        "format-icons": {
            "activated": "َ°¥”",
            "deactivated": "ïگ؛"
        }
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%R َ°ƒ­ %dآ·%mآ·%y}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "tray": {
        "icon-size": 12,
        "spacing": 5
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon} {capacity}%",
        "format-charging": "ï‡¦ {capacity}%",
        "format-plugged": "ï‡¦ {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
    },

    "custom/wallchange": {
        "format": "َ°¸‰",
        "exec": "echo ; echo َ°†ٹ switch wallpaper",
        "on-click": "~/.config/hypr/scripts/swwwallpaper.sh -n",
        "on-click-right": "~/.config/hypr/scripts/swwwallpaper.sh -p",
        "on-click-middle": "sleep 0.1 && ~/.config/hypr/scripts/swwwallselect.sh",
        "interval" : 86400, // once every day
        "tooltip": true
    },

    "custom/mode": {
        "format": "َ°”ژ",
        //"format": "îˆ«{}",
        "exec": "echo ; echo َ°ں، switch mode",
        "on-click": "~/.config/hypr/scripts/themeswitch.sh -n",
        "on-click-right": "~/.config/hypr/scripts/themeswitch.sh -p",
        "on-click-middle": "sleep 0.1 && ~/.config/hypr/scripts/themeselect.sh",
        "interval" : 86400, // once every day
        "tooltip": true
    },

    "custom/wbar": {
        "format": "َ±”“", // ï‹•  ï†¥ //
        "exec": "echo ; echo ïˆ… switch menubar // ï‹• dock",
        "on-click": "~/.config/hypr/scripts/wbarconfgen.sh n",
        "on-click-right": "~/.config/hypr/scripts/wbarconfgen.sh p",
        "on-click-middle": "sleep 0.1 && ~/.config/hypr/scripts/quickapps.sh kitty brave spotify codium dolphin",
        "interval" : 86400,
        "tooltip": true
    },

    "custom/cliphist": {
        "format": "َ±‰¦",
        "exec": "echo ; echo َ°…‡ clipboard history",
        "on-click": "sleep 0.1 && ~/.config/hypr/scripts/cliphist.sh c",
        "on-click-right": "sleep 0.1 && ~/.config/hypr/scripts/cliphist.sh d",
        "on-click-middle": "sleep 0.1 && ~/.config/hypr/scripts/cliphist.sh w",
        "interval" : 86400, // once every day
        "tooltip": true
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["îژچ", "îڈ“", "îڈ‘", "îڈڈ", "îڈژ", "îڈچ", "îڈٹ", "îڈˆ", "îژ›"],
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-",
        "min-length": 6
    },

    "network": {
        "tooltip": true,
        "format": "َ°¤©",
        "format-wifi": "{icon}",
        "format-ethernet": "َ°ˆ€",
        "format-linked": "َ°ˆ€ {ifname} (No IP)",
        "format-disconnected": "َ°¤­",
        "format-alt": "<span foreground='#99ffdd'>َ°‡ڑ {bandwidthDownBytes}</span> <span foreground='#ffcc66'>َ°•’ {bandwidthUpBytes}</span>",
        "on-click-middle": "~/.config/hypr/scripts/networkcontrol.sh p",
        "on-click-right": "kitty nmtui",
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 2,
        "format-icons": {
            "default": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"]
        }
    },

    "bluetooth": {
        "format-on": "َ°‚¯",
        "format-alt": "{status} َ°‚¯",
        "format-off": "َ°‚²",
        "format-connected": "{num_connections} َ°‚±",
        "format-connected-battery": "{num_connections} {icon}",
        // "format-connected-battery": "{icon} {device_alias}-{device_battery_percentage}%",
        "format-icons": ["َ°¥‡", "َ°¤¾", "َ°¤؟", "َ°¥€", "َ°¥پ", "َ°¥‚", "َ°¥ƒ", "َ°¥„", "َ°¥…", "َ°¥†", "َ°¥ˆ"],
        // "format-device-preference": [ "device1", "device2" ], // preference list deciding the displayed device If this config option is not defined or none of the devices in the list are connected, it will fall back to showing the last connected device.
        "on-click-middle": "~/.config/hypr/scripts/bluetoothcontrol.sh p",
        "on-click-right": "blueman-manager",
        "tooltip-format-on": "{controller_alias} // on",
        "tooltip-format-off": "{controller_alias} // off",
        "tooltip-format-connected": "{controller_alias} // {num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{icon} {device_battery_percentage}%"
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "َ°–پ",
        "format-alt": "{volume}% {icon}",
        "on-click-middle": "~/.config/hypr/scripts/volumecontrol.sh -o m",
        "on-click-right": "pavucontrol -t 3",
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh -o i",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh -o d",
        "tooltip-format": "{icon} {desc} // {volume}%",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "ï€¥",
            "hands-free": "ï€¥",
            "headset": "ï€¥",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        }
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-alt": "{source_volume}% {format_source}",
        "format-source": "َ°چ¬",
        "format-source-muted": "َ°چ­",
        "on-click-middle": "~/.config/hypr/scripts/volumecontrol.sh -i m",
        "on-click-right": "pavucontrol -t 4",
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh -i i",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh -i d",
        "tooltip-format": "{format_source} {source_desc} // {source_volume}%",
        "scroll-step": 5
    },

    "custom/updates": {
        "exec": "~/.config/hypr/scripts/systemupdate.sh",
        "return-type": "json",
        "format": "َ°ڑ°",
        "format-alt": "{} َ°ڑ°",
        "on-click-right": "~/.config/hypr/scripts/systemupdate.sh u",
        "interval": 3600, // once every day
        "tooltip": true
    },

    "custom/notification": {
      "tooltip": true,
      "tooltip-format": "{} notifications",
      "format": "{icon}",
      "format-alt": "{} {icon}",
      "format-icons": {
        "notification": "َ°‚ڑ",
        "none": "َ°‚œ",
        "dnd-notification": "َ°‚›",
        "dnd-none": "َ°ھ‘",
        "inhibited-notification": "َ°‚ڑ",
        "inhibited-none": "َ°‚œ",
        "dnd-inhibited-notification": "َ°‚›",
        "dnd-inhibited-none": "َ°ھ‘"
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click-middle": "swaync-client -d -sw",
      "on-click-right": "swaync-client -t -sw",
      "escape": true
    },
    "custom/power": {
        "format": "ï€‘",
        "exec": "echo ; echo ï€‘ logout",
        "on-click": "~/.config/hypr/scripts/logoutlaunch.sh 2",
        "on-click-right": "~/.config/hypr/scripts/logoutlaunch.sh 1",
        "interval" : 86400, // once every day
        "tooltip": true
    },


// modules for padding //

    "custom/l_end": {
        "format": " ",
        "interval" : "once",
        "tooltip": false
    },

    "custom/r_end": {
        "format": " ",
        "interval" : "once",
        "tooltip": false
    },

    "custom/sl_end": {
        "format": " ",
        "interval" : "once",
        "tooltip": false
    },

    "custom/sr_end": {
        "format": " ",
        "interval" : "once",
        "tooltip": false
    },

    "custom/rl_end": {
        "format": " ",
        "interval" : "once",
        "tooltip": false
    },

    "custom/rr_end": {
        "format": " ",
        "interval" : "once",
        "tooltip": false
    },

    "custom/padd": {
        "format": "  ",
        "interval" : "once",
        "tooltip": false
    }

}

